    "def penalty_matrix(K, order=3):\n",
    "    D = np.diff(np.eye(K), n=order, axis=0)\n",
    "    return D.T @ D\n",
    "    \n",
    "def penalized_spline_fit(B, Y, lam):\n",
    "    K = B.shape[1]\n",
    "    P = penalty_matrix(K)  # ← remplace np.eye\n",
    "    beta = solve(B.T @ B + lam * P, B.T @ Y)\n",
    "    return beta, B @ beta"
   ]
  },
