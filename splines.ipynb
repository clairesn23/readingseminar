    "\n",
    "def smoothing_matrix(B, lam):\n",
    "    K = B.shape[1]\n",
    "    P = penalty_matrix(K)\n",
    "    return B @ solve(B.T @ B + lam * P, B.T)\n",
    "    \n",
    "def compute_edf(B, lam):\n",
    "    return np.trace(smoothing_matrix(B, lam))"
   ]
  },
