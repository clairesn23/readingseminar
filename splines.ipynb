    "        markersize=6,\n",
    "        label=\"Signal original\"\n",
    "    )\n",
    "    \n",
    "    # Spline pénalisée pour ce nombre de nœuds\n",
    "    B = build_bspline_basis(t_numeric, n_knots)\n",
    "    lam_opt = optimize_lambda_gcv(B, values)\n",
    "    _, Y_hat = penalized_spline_fit(B, values, lam_opt)\n",
    "    \n",
    "    plt.plot(\n",
    "        dates,\n",
    "        Y_hat,\n",
